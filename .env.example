# AetherKin Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# === REQUIRED FOR TELEGRAM ===
# Create a bot via @BotFather on Telegram, paste the token here
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Your Telegram user ID (send /start to @userinfobot to find yours)
TELEGRAM_CHAT_ID=your_chat_id_here

# Comma-separated Telegram user IDs allowed to use the bot
ALLOWED_TELEGRAM_USERS=your_user_id_here

# === REQUIRED FOR GROQ (Free Tier) ===
# Sign up at console.groq.com, create an API key
GROQ_API_KEY=your_groq_api_key_here

# Optional: change the model (default: llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile

# === OPTIONAL: Custom paths ===
# Where your agent folders live (each with .claude/CLAUDE.md)
# Defaults to ./family if not set
# AETHERKIN_FAMILY_ROOT=/path/to/your/agent/folders
